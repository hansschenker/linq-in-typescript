{
  "name": "linq-in-typescript",
  "version": "1.0.0",
  "description": "An implementation of .NET's LINQ API in TypeScript, using generators and the ES iterator protocol for lazy evaluation",
  "keywords": [
    "linq",
    "typescript",
    "lazy",
    "enumerable"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./operators": {
      "types": "./dist/operators.d.ts",
      "default": "./dist/operators.js"
    },
    "./async": {
      "types": "./dist/async/index.d.ts",
      "default": "./dist/async/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hansschenker/linq-in-typescript.git"
  },
  "homepage": "https://github.com/hansschenker/linq-in-typescript#readme",
  "bugs": {
    "url": "https://github.com/hansschenker/linq-in-typescript/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
